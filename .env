# Copy this file to .env (for local dev with `vercel dev`) and fill in your key.
# In production (Vercel), set these as Environment Variables in the project
# dashboard instead — never commit a real key to the repo.

# Your OpenRouter API key. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=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

# Optional: used in the HTTP-Referer header sent to OpenRouter for
# analytics/rate-limit attribution. Set this to your deployed Vercel URL
# once you have one (e.g. https://simba-clause-finder.vercel.app).
PUBLIC_APP_URL=https://simba-clause-finder.vercel.app
